# ============================================================
# 이 파일을 복사해서 ".env" 로 저장한 뒤 실제 값을 채워 넣으세요.
# ".env" 파일은 .gitignore 에 포함되어 있어 GitHub에 절대 올라가지 않습니다.
# 배포 시(Vercel/Netlify)에는 이 값들을 "대시보드의 환경변수 설정"에
# 직접 등록하고, 이 .env 파일은 로컬 개발용으로만 사용하세요.
# ============================================================

# ── 서버 전용 비밀 값 (절대 VITE_ 접두어를 붙이지 마세요 = 브라우저 노출 방지) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── 프론트엔드에 노출되어도 되는 값 (OAuth Client ID는 공개값이므로 VITE_ 접두어 사용) ──
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 발급
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# 승인된 자바스크립트 원본(Authorized JavaScript origins)에
# 로컬 개발 주소(http://localhost:5173)와 배포 도메인을 모두 등록해야 합니다.
